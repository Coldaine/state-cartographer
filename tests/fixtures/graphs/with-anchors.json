{
  "initial_state": "main_menu",
  "states": {
    "main_menu": {
      "anchors": [
        {"type": "text_match", "pattern": "Welcome, Commander", "cost": 2},
        {"type": "dom_element", "selector": "#main-menu-container", "cost": 1}
      ],
      "negative_anchors": [
        {"type": "dom_element", "selector": ".loading-spinner"}
      ],
      "confidence_threshold": 0.7
    },
    "dock": {
      "anchors": [
        {"type": "dom_element", "selector": "#dock-header", "cost": 1},
        {"type": "text_match", "pattern": "Dock", "cost": 2}
      ],
      "negative_anchors": [],
      "confidence_threshold": 0.7
    },
    "formation": {
      "anchors": [
        {"type": "dom_element", "selector": "#formation-panel", "cost": 1},
        {"type": "text_match", "pattern": "Formation", "cost": 2}
      ],
      "negative_anchors": [],
      "confidence_threshold": 0.7
    },
    "sortie_select": {
      "anchors": [
        {"type": "text_match", "pattern": "Select Stage", "cost": 2}
      ],
      "negative_anchors": [],
      "confidence_threshold": 0.8
    },
    "auto_battle": {
      "anchors": [
        {"type": "text_match", "pattern": "Auto", "cost": 2}
      ],
      "negative_anchors": [],
      "wait_state": true,
      "expected_duration_range": [30000, 120000],
      "poll_interval": 5000,
      "exit_signals": [
        {"type": "text_match", "pattern": "Victory|Defeat"}
      ],
      "confidence_threshold": 0.7
    },
    "battle_result": {
      "anchors": [
        {"type": "text_match", "pattern": "Victory", "cost": 2},
        {"type": "text_match", "pattern": "Defeat", "cost": 2}
      ],
      "negative_anchors": [],
      "confidence_threshold": 0.7
    },
    "purchase_confirm": {
      "anchors": [
        {"type": "text_match", "pattern": "Confirm Purchase", "cost": 2}
      ],
      "negative_anchors": [],
      "confidence_threshold": 0.99,
      "on_low_confidence": "vision_review",
      "irreversible": true
    }
  },
  "transitions": {
    "main_to_dock": {
      "source": "main_menu",
      "dest": "dock",
      "method": "deterministic",
      "action": {"type": "adb_tap", "x": 450, "y": 800},
      "cost": 1
    },
    "main_to_formation": {
      "source": "main_menu",
      "dest": "formation",
      "method": "deterministic",
      "action": {"type": "adb_tap", "x": 300, "y": 800},
      "cost": 1
    },
    "main_to_sortie": {
      "source": "main_menu",
      "dest": "sortie_select",
      "method": "deterministic",
      "action": {"type": "adb_tap", "x": 600, "y": 400},
      "cost": 2
    },
    "sortie_to_battle": {
      "source": "sortie_select",
      "dest": "auto_battle",
      "method": "vision_required",
      "action": {"type": "screenshot_then_click", "description": "select stage and start"},
      "cost": 50
    },
    "battle_to_result": {
      "source": "auto_battle",
      "dest": "battle_result",
      "method": "deterministic",
      "action": {"type": "wait_for_exit_signal"},
      "cost": 1
    },
    "result_to_main": {
      "source": "battle_result",
      "dest": "main_menu",
      "method": "deterministic",
      "action": {"type": "adb_tap", "x": 640, "y": 600},
      "cost": 1
    },
    "dock_to_main": {
      "source": "dock",
      "dest": "main_menu",
      "method": "deterministic",
      "action": {"type": "press_back"},
      "cost": 1
    },
    "formation_to_main": {
      "source": "formation",
      "dest": "main_menu",
      "method": "deterministic",
      "action": {"type": "press_back"},
      "cost": 1
    },
    "dock_to_formation": {
      "source": "dock",
      "dest": "formation",
      "method": "deterministic",
      "action": {"type": "adb_tap", "x": 200, "y": 100},
      "cost": 2
    }
  }
}
