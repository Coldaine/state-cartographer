#!/usr/bin/env bash
# Pre-commit hook: autofix formatting on staged Python files.
# Order: ruff check --fix first, then ruff format (per Astral best practice).
# Re-stages fixed files so the commit includes the corrections.
set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.pyi?$' || true)
[ -z "$STAGED" ] && exit 0

uv run --extra dev ruff check --fix $STAGED
uv run --extra dev ruff format $STAGED

git add $STAGED
